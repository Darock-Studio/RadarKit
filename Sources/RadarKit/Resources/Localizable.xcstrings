    "“反馈助理”不可用，因为暗礁浏览器有更新可用" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feedback Assistant not available, because Darock Browser has an update available"
          }
        }
      }
    },
